{
  "api_url": {
    "description": "CLIProxy 的 /v1/responses 接口地址",
    "type": "string",
    "hint": "例如 https://your-proxy.example.com/v1/responses",
    "obvious_hint": true
  },
  "api_key": {
    "description": "CLIProxy API Key",
    "type": "string",
    "hint": "将会以 Bearer Token 方式写入 Authorization 请求头",
    "obvious_hint": true
  },
  "model": {
    "description": "生图模型名",
    "type": "string",
    "default": "gpt-image-1536x1024",
    "hint": "请填写你的代理实际支持的模型名"
  },
  "instructions": {
    "description": "附加系统提示词",
    "type": "text",
    "default": "You are a helpful assistant.",
    "hint": "会放到 Responses API 的 instructions 字段"
  },
  "stream": {
    "description": "是否使用 SSE 流式响应",
    "type": "bool",
    "default": true,
    "hint": "如果你的代理不支持 stream=true，可关闭此项"
  },
  "timeout_seconds": {
    "description": "请求超时时间（秒）",
    "type": "int",
    "default": 180
  },
  "parallel_tool_calls": {
    "description": "是否发送 parallel_tool_calls 字段",
    "type": "bool",
    "default": true
  },
  "store": {
    "description": "是否让接口存储响应",
    "type": "bool",
    "default": false
  },
  "reasoning_effort": {
    "description": "reasoning.effort",
    "type": "string",
    "default": "",
    "hint": "例如 high；留空则不发送 reasoning.effort"
  },
  "reasoning_summary": {
    "description": "reasoning.summary",
    "type": "string",
    "default": "",
    "hint": "例如 auto；留空则不发送 reasoning.summary"
  },
  "include_reasoning_encrypted_content": {
    "description": "是否附带 reasoning.encrypted_content",
    "type": "bool",
    "default": false
  },
  "send_revised_prompt": {
    "description": "发送图片后是否额外回发 revised_prompt",
    "type": "bool",
    "default": false
  }
}
